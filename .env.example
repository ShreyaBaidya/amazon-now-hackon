# Amazon Now — environment variables
# Copy to .env or .env.local (in repo root or backend/) and fill in values.
# These files are gitignored — never commit secrets.
AWS_REGION=ap-south-1
# ── AWS Bedrock ──────────────────────────────────────────────────────────────
# Region and inference-profile model ID for Amazon Bedrock (Nova Lite default)
BEDROCK_REGION=ap-south-1
BEDROCK_MODEL_ID=apac.amazon.nova-lite-v1:0

# ── Google Calendar OAuth 2.0 ─────────────────────────────────────────────────
# Create a project at https://console.cloud.google.com/
# Enable the Google Calendar API, create OAuth 2.0 credentials (Web application type).
# Add http://127.0.0.1:8010/api/calendar/callback as an Authorised redirect URI.

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# The redirect URI must exactly match what you registered in Google Cloud Console.
# Default: http://127.0.0.1:8010/api/calendar/callback
GOOGLE_REDIRECT_URI=http://127.0.0.1:8010/api/calendar/callback

# ── Frontend ──────────────────────────────────────────────────────────────────
# Base URL of the FastAPI backend (used by Next.js)
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8010

# Origin of the frontend for OAuth post-auth redirect (default: http://localhost:3000)
# Set this to your deployed frontend URL in production (e.g. https://your-domain.com)
FRONTEND_ORIGIN=http://localhost:3000
